# ==================================================
# SERVER CONFIGURATION
# ==================================================
PORT=3000
NODE_ENV=development

# ==================================================
# DATABASE CONFIGURATION (PostgreSQL / Supabase)
# ==================================================
# Option 1: Supabase (Recommandé pour la production)
DB_HOST=db.example.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_SUPABASE_PASSWORD_HERE

# Option 2: PostgreSQL Local (Développement)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=securescan
# DB_USER=postgres
# DB_PASSWORD=postgres

# ==================================================
# JWT AUTHENTICATION
# ==================================================
# Secret pour signer les tokens JWT (OBLIGATOIRE)
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_change_in_production_use_strong_random_string
JWT_EXPIRES_IN=7d

# ==================================================
# FILE STORAGE & TEMPORARY DIRECTORIES
# ==================================================
TEMP_REPOS_DIR=./temp/repos
TEMP_UPLOADS_DIR=./temp/uploads

# ==================================================
# GITHUB INTEGRATION (Optionnel)
# ==================================================
# Token GitHub pour créer des Pull Requests automatiquement
# Générer sur: https://github.com/settings/tokens
# Permissions requises: repo (Full control of private repositories)
GITHUB_TOKEN=

# ==================================================
# CLAUDE AI API (Optionnel - Corrections IA)
# ==================================================
# Clé API Anthropic Claude pour générer des corrections intelligentes
# Obtenir sur: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# ==================================================
# ENCRYPTION (Sécurité)
# ==================================================
# Clé de chiffrement pour les tokens GitHub stockés (OBLIGATOIRE)
# Doit faire exactement 32 caractères
# Générer avec: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=change-in-prod-32bytes-exactly

# ==================================================
# SECURITY SCANNING TOOLS
# ==================================================
# Semgrep est installé via pip (pip install semgrep)
# Aucune configuration supplémentaire requise

# ==================================================
# CORS CONFIGURATION (Frontend URL)
# ==================================================
# URL du frontend autorisée pour CORS
FRONTEND_URL=http://localhost:5173

# ==================================================
# LOGS & MONITORING
# ==================================================
# Niveau de logs (error, warn, info, debug)
LOG_LEVEL=info

# ==================================================
# CLEANUP CONFIGURATION
# ==================================================
# Durée de rétention des scans temporaires (en jours)
CLEANUP_RETENTION_DAYS=7