# ==================================================
# BACKEND API CONFIGURATION
# ==================================================
# URL de base du backend API
# Développement: http://localhost:3000/api
# Production: https://votre-domaine.com/api
VITE_API_URL=http://localhost:3000/api

# ==================================================
# APPLICATION CONFIGURATION
# ==================================================
# Nom de l'application affiché dans l'interface
VITE_APP_NAME=SecureScan

# Version de l'application (optionnel)
VITE_APP_VERSION=1.0.0

# ==================================================
# ENVIRONMENT
# ==================================================
# Environnement d'exécution (development, production)
VITE_ENV=development

# ==================================================
# FEATURES FLAGS (Optionnel)
# ==================================================
# Activer/désactiver certaines fonctionnalités
VITE_ENABLE_GITHUB_INTEGRATION=true
VITE_ENABLE_AI_CORRECTIONS=true

# ==================================================
# NOTES
# ==================================================
# - Toutes les variables doivent commencer par VITE_ pour être accessibles
# - Ne jamais commiter de fichier .env avec des vraies valeurs sensibles
# - Utiliser .env.local pour vos valeurs locales (ignoré par Git)
